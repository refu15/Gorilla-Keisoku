`;

  const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent`;
  
  try {
    const response = UrlFetchApp.fetch(url, {
      method: 'POST',
      contentType: 'application/json',
      headers: { 'x-goog-api-key': DAILY_CONFIG.GEMINI_API_KEY },
      payload: JSON.stringify({
        contents: [{ parts: [{ text: prompt }] }],
        generationConfig: { temperature: 0.7, maxOutputTokens: 2048 }
      })
    });
    
    const json = JSON.parse(response.getContentText());
    return json.candidates?.[0]?.content?.parts?.[0]?.text || '日報のテキスト生成に失敗しました（Geminiから空のレスポンス）。';
  } catch (e) {
    Logger.log('Gemini APIエラー: ' + e.message);
    return 'AI日報生成エラー: ' + e.message;
  }
}

/**
 * Slackへ通知を行う
 */
function sendSlackMessage(text) {
  const webhookUrl = DAILY_CONFIG.SLACK_WEBHOOK_URL;
  if (!webhookUrl) {
    Logger.log('Slack Webhook URLが設定されていません。');
    return;
  }
  
  const payload = {
    text: text
  };
  
  const options = {
    method: 'post',
    contentType: 'application/json',
    payload: JSON.stringify(payload)
  };
  
  try {
    UrlFetchApp.fetch(webhookUrl, options);
  } catch(e) {
    Logger.log('Slack通知エラー: ' + e.message);
  }
}

/**
 * ========================================
 * 毎日の自動実行トリガーを設定するための関数
 * （一度だけGASエディタ上で手動実行してください）
 * ========================================
 */
function setupDailyTrigger() {
  // 既存の同名トリガーを削除（重複防止）
  const triggers = ScriptApp.getProjectTriggers();
  triggers.forEach(trigger => {
    if (trigger.getHandlerFunction() === 'checkAndGenerateDailyReport') {
      ScriptApp.deleteTrigger(trigger);
    }
  });
  
  // 毎日指定時間（例: 18時台）に実行するトリガーを作成
  ScriptApp.newTrigger('checkAndGenerateDailyReport')
    .timeBased()
    .everyDays(1)
    .atHour(DAILY_CONFIG.TRIGGER_HOUR)
    .create();
    
  Logger.log(`毎日の日報未提出アラート＆自動生成トリガーを設定しました（毎日 ${DAILY_CONFIG.TRIGGER_HOUR} 時台に実行されます）`);
}
